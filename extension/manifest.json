{
  "manifest_version": 3,
  "name": "PageTune",
  "version": "0.1.0",
  "description": "Adjust text and image size; page-aware help with optional AI.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://api.openai.com/*"],
  "action": { "default_title": "PageTune", "default_popup": "action/popup.html" },
  "options_ui": { "page": "options/options.html", "open_in_tab": true },
  "background": { "service_worker": "background/service-worker.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/analyze.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/panel.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
