# Anthropic — required for chat + content generation
ANTHROPIC_API_KEY=

# Supabase — required for persistence (sites, visitors, preferences, chat_turns)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Management API — required for `pnpm migrate` only (Account → Access Tokens)
SUPABASE_ACCESS_TOKEN=

# Optional — Unsplash for video thumbnail seeds
UNSPLASH_ACCESS_KEY=

# Feed source: mock | youtube | amazon | instagram
# YouTube home (/) uses live feed only when this is "youtube".
# /amazon, /instagram, and /slack use live intercept adapters unless set to "mock".
SHOWCASE_FEED_SOURCE=mock
FEED_ADAPTER=mock

# macOS Chrome cookies for live intercept feeds (YouTube, Amazon, Instagram, Slack).
# CHROME_COOKIE_PATH="/Users/you/Library/Application Support/Google/Chrome/Profile 1/Cookies"

# Amazon intercept: default search query when home/chips load
AMAZON_SEARCH_QUERY=best sellers

# Slack intercept: xoxc session token from Slack DevTools (see docs/slack.md)
# SLACK_XOXC=xoxc-...
# Optional: open this channel on load (name without #, or channel ID)
# SLACK_DEFAULT_CHANNEL=general
# SLACK_DEFAULT_CHANNEL_ID=C0123456789

# Optional: prefer this workspace when multiple Slack teams are in Chrome (substring match)
# SLACK_WORKSPACE=CS194

# Slack intercept on production (default: blocked). Never enable on public deploy unless intentional.
# SLACK_INTERCEPT_ENABLED=true

# Dev-only flags (set false or omit in production — see docs/security.md)
NEXT_PUBLIC_DEVTOOLS_ENABLED=true
